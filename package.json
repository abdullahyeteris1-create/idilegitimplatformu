{
  "name": "idilegitimplatformu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:mobile": "next dev --hostname 0.0.0.0",
    "dev:webpack": "next dev --webpack --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "start:mobile": "next start -H 0.0.0.0",
    "clean": "rmdir /s /q .next",
    "stop-node": "taskkill /IM node.exe /F || exit /b 0",
    "mobile:prod": "npm run build && npm run start:mobile",
    "test:mobile": "taskkill /IM node.exe /F || echo node.exe not running && rmdir /s /q .next && npm run build && npm run start:mobile",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "next": "16.2.10",
    "openai": "^6.46.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
